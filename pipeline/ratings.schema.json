{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Raumdeuter player rating",
  "type": "object",
  "required": ["name", "team", "pos", "archetype", "onBall", "offBall", "meta"],
  "properties": {
    "name": { "type": "string" },
    "team": { "type": "string", "description": "FIFA trigram" },
    "pos": { "enum": ["GK", "DF", "MF", "FW"] },
    "archetype": { "type": "string" },
    "onBall": {
      "type": "object",
      "required": ["fin", "cre", "prg"],
      "properties": {
        "fin": { "type": "integer", "minimum": 0, "maximum": 99 },
        "cre": { "type": "integer", "minimum": 0, "maximum": 99 },
        "prg": { "type": "integer", "minimum": 0, "maximum": 99 }
      }
    },
    "offBall": {
      "type": "object",
      "required": ["prs", "rgn", "mov", "cov"],
      "properties": {
        "prs": { "type": "integer", "minimum": 0, "maximum": 99 },
        "rgn": { "type": "integer", "minimum": 0, "maximum": 99 },
        "mov": { "type": "integer", "minimum": 0, "maximum": 99 },
        "cov": { "type": "integer", "minimum": 0, "maximum": 99 }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "minutes": { "type": "integer" },
        "source": { "enum": ["statsbomb", "curated"] },
        "asOf": { "type": "string", "format": "date" }
      }
    }
  }
}
